    "html": "<html><head><meta name=\"color-scheme\" content=\"light dark\"></head><body><pre style=\"word-wrap: break-word; white-space: pre-wrap;\">{% extends \"base.html\" %}\n\n{% block title %}MMSS Semantic Orchestrator v2.0{% endblock %}\n\n{% block head %}\n{{ super() }}\n<!-- <script src=\"https://cdn.tailwindcss.com\"></script> -->\n<!-- <script src=\"https://cdn.jsdelivr.net/npm/marked/marked.min.js\"></script> -->\n<!-- <script src=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js\"></script> -->\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css\">\n<style>\n    /* @import \"tailwindcss\"; */\n@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Inter+Tight:wght@500;600&family=DM+Mono:wght@400&display=swap');\n\n\n</style>\n{% endblock %}\n\n{% block content %}\n<header class=\"header\">\n    <div class=\"header-controls\">\n        <button id=\"save-project\" class=\"header-btn\">💾 Сохранить проект</button>\n        <button id=\"download-results\" class=\"header-btn\">📥 Скачать JSON</button>\n        <button id=\"load-project\" class=\"header-btn\">📂 Загрузить проект</button>\n        <button id=\"fill-all-prompts\" class=\"header-btn\">✍️ Заполнить все промпты</button>\n        <button id=\"auto-cycle\" class=\"header-btn\">🔄 Auto Cycle</button>\n        <button id=\"grid-toggle\" class=\"header-btn\">🔢 Grid: 3</button>\n        <button id=\"restore-memory-tools\" class=\"header-btn\">🧠 Restore MemoryTools</button>\n        <button id=\"create-summary-response\" class=\"header-btn\">📝 Создать сводный ответ</button>\n    </div>\n    <h1 class=\"header-title\">MMSS Orchestrator</h1>\n    <div class=\"system-info\">\n        <div style=\"display:flex; gap:12px; justify-content:center; align-items:center; flex-wrap:wrap;\">\n            <label for=\"orchestrator-provider\">Provider</label>\n            <select id=\"orchestrator-provider\" class=\"prompt-type\" style=\"max-width: 220px;\">\n                <option value=\"ollama\" {% if selected_provider == 'ollama' %}selected{% endif %}>Local Ollama</option>\n                <option value=\"mistral\" {% if selected_provider == 'mistral' %}selected{% endif %}>Mistral</option>\n            </select>\n            <label for=\"orchestrator-ollama-model\">Local Ollama Model</label>\n            <select id=\"orchestrator-ollama-model\" class=\"prompt-type\" style=\"max-width: 360px;\">\n                {% for model in ollama_models %}\n                    <option value=\"{{ model }}\" {% if model == selected_model %}selected{% endif %}>{{ model }}</option>\n                {% endfor %}\n            </select>\n            <button id=\"refresh-orchestrator-models\" class=\"header-btn\">Refresh Models</button>\n            <label for=\"orchestrator-mistral-model\">Mistral Model</label>\n            <select id=\"orchestrator-mistral-model\" class=\"prompt-type\" style=\"max-width: 320px;\">\n                {% for model in mistral_models %}\n                    <option value=\"{{ model }}\" {% if model == selected_mistral_model %}selected{% endif %}>{{ model }}</option>\n                {% endfor %}\n            </select>\n            <button id=\"refresh-orchestrator-mistral-models\" class=\"header-btn\">Refresh Mistral</button>\n        </div>\n        {% if ollama_error %}\n            <div style=\"margin-top:8px; color:#fbbf24;\">{{ ollama_error }}</div>\n        {% endif %}\n        {% if mistral_error %}\n            <div style=\"margin-top:8px; color:#fbbf24;\">{{ mistral_error }}</div>\n        {% endif %}\n        <div id=\"service-health-panel\" style=\"margin-top:12px; display:flex; gap:12px; justify-content:center; flex-wrap:wrap;\">\n            {% for service_name, service_state in service_health.items() %}\n                <div style=\"padding:8px 12px; border-radius:8px; background: rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12);\">\n                    <strong>{{ service_name }}</strong>:\n                    {% if service_state.reachable %}\n                        <span style=\"color:#64ffda;\">online</span>\n                    {% else %}\n                        <span style=\"color:#f87171;\">offline</span>\n                    {% endif %}\n                </div>\n            {% endfor %}\n        </div>\n    </div>\n    <!-- Panel for MemoryTools (presets) -->\n    <div id=\"memory-tools-panel\">\n        <h3>Сохраненные инструменты (MemoryTools)</h3>\n        <div class=\"memory-tool-buttons\">\n            <!-- Presets will be loaded here by JavaScript -->\n        </div>\n    </div>\n</header>\n<div class=\"min-h-screen bg-gray-900 text-gray-200 font-sans\">\n    <div class=\"p-4\">\n        <!-- Top Panel -->\n        <div class=\"top-panel bg-gray-800 border border-gray-700 rounded-lg p-4 flex flex-col\">\n            <h1 class=\"text-2xl font-bold mb-4\">MMSS Orchestrator</h1>\n            <textarea id=\"question\" class=\"w-full bg-gray-700 border-2 border-gray-600 rounded-lg p-4 text-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 flex-grow resize-none\" placeholder=\"Введите ваш вопрос...\"></textarea>\n        </div>\n\n        <!-- Grid Panel -->\n        <div class=\"grid-panel mt-4\">\n            <!-- Agent cards will be inserted here by JavaScript -->\n        </div>\n   \n    </div>\n</div>\n\n<!-- Modal for loading projects -->\n<div id=\"load-project-modal\" class=\"modal-overlay\">\n    <div class=\"modal-content\">\n        <span class=\"close-modal\" id=\"close-project-modal\">&times;</span>\n        <h2>Выберите проект для загрузки</h2>\n        <ul id=\"project-list\">\n            <!-- Project list will be populated by JavaScript -->\n        </ul>\n    </div>\n</div>\n\n<!-- Modal for creating new tools -->\n<div id=\"create-tool-modal\" class=\"modal-overlay\">\n    <div class=\"modal-content\">\n        <span class=\"close-modal\" id=\"close-create-tool-modal\">&times;</span>\n        <h2>Создать новый инструмент</h2>\n        <input type=\"text\" id=\"tool-name-input\" placeholder=\"Название действия (например, 'Максимально детализировать')\">\n        <textarea id=\"tool-prompt-input\" rows=\"5\" placeholder=\"Текст промпта (используйте {{selected_text}} для выделенного текста)\"></textarea>\n        <div class=\"checkbox-container\">\n            <input type=\"checkbox\" id=\"save-as-preset-checkbox\">\n            <label for=\"save-as-preset-checkbox\">Сохранить как пресет</label>\n        </div>\n        <button id=\"save-tool-button\">Сохранить инструмент</button>\n        <button id=\"cancel-tool-button\">Отмена</button>\n    </div>\n</div>\n\n\n{% endblock %}\n\n{% block scripts %}\n<script src=\"{{ url_for('static', filename='js/orchestrator_main.js') }}\"></script>\n<script src=\"{{ url_for('static', filename='js/orchestrator_v2.js') }}\"></script>\n{% endblock %}\n</pre></body></html>",
