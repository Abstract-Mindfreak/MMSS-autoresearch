    "html": "<html><head><meta name=\"color-scheme\" content=\"light dark\"></head><body><pre style=\"word-wrap: break-word; white-space: pre-wrap;\"><!DOCTYPE html>\n<html lang=\"ru\" data-theme=\"{{ theme if theme else 'light' }}\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>{% block title %}MMSS System{% endblock %}</title>\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"{{ url_for('static', filename='favicon.ico') }}\">\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/golden-layout@2.6.0/dist/css/goldenlayout-base.css\">\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/golden-layout@2.6.0/dist/css/themes/goldenlayout-dark-theme.css\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <link rel=\"stylesheet\" href=\"{{ url_for('static', filename='css/style.css') }}\">\n    {% if custom_theme_css %}\n    <link rel=\"stylesheet\" href=\"{{ custom_theme_css }}\">\n    {% endif %}\n    <style>\n        html, body {\n            min-height: 100%;\n        }\n        body {\n            margin: 0;\n            background: #0f172a;\n        }\n        body.gl-enabled {\n            height: 100vh;\n            overflow: hidden;\n        }\n        #golden-layout-root {\n            display: none;\n            height: 100vh;\n            width: 100vw;\n        }\n        body.gl-enabled #golden-layout-root {\n            display: block;\n        }\n        body.gl-enabled #app-fallback-root {\n            display: none;\n        }\n        .gl-source-panel,\n        .gl-content-panel {\n            height: 100%;\n            overflow: auto;\n            background: #0f172a;\n        }\n        .gl-nav-panel .navbar {\n            border-radius: 0;\n        }\n        #gl-source-panels {\n            position: absolute;\n            left: -99999px;\n            top: 0;\n            width: 1px;\n            height: 1px;\n            overflow: hidden;\n        }\n    </style>\n    {% block head %}{% endblock %}\n</head>\n<body>\n    <div id=\"app-fallback-root\">\n        <nav class=\"navbar navbar-expand-lg navbar-dark bg-dark\">\n            <div class=\"container\">\n                <a class=\"navbar-brand\" href=\"{{ url_for('index') }}\">\n                    <i class=\"fas fa-cube\"></i> MMSS System\n                </a>\n                <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarNav\">\n                    <span class=\"navbar-toggler-icon\"></span>\n                </button>\n                <div class=\"collapse navbar-collapse\" id=\"navbarNav\">\n                    <ul class=\"navbar-nav ms-auto\">\n                        <li class=\"nav-item\">\n                            <button class=\"nav-link btn btn-link\" id=\"theme-toggle\" aria-label=\"Toggle theme\">\n                                <i class=\"fas fa-sun\"></i>\n                            </button>\n                        </li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('index') }}\"><i class=\"fas fa-home\"></i> Главная</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('activate') }}\"><i class=\"fas fa-power-off\"></i> Активация</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('dashboard') }}\"><i class=\"fas fa-chart-line\"></i> Дашборд</a></li>\n                        <li class=\"nav-item dropdown\">\n                            <a class=\"nav-link dropdown-toggle\" href=\"#\" id=\"modulesDropdown\" role=\"button\" data-bs-toggle=\"dropdown\">\n                                <i class=\"fas fa-puzzle-piece\"></i> Модули\n                            </a>\n                            <ul class=\"dropdown-menu\">\n                                <li><a class=\"dropdown-item\" href=\"{{ url_for('pfr') }}\">PFR - Фрактальная Пересборка</a></li>\n                                <li><a class=\"dropdown-item\" href=\"{{ url_for('frp') }}\">FRP - Темпоральная Навигация</a></li>\n                                <li><a class=\"dropdown-item\" href=\"{{ url_for('ammss') }}\">A-MMSS - Плетение Контекста</a></li>\n                            </ul>\n                        </li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('prompt_generator_page') }}\"><i class=\"fas fa-robot\"></i> Генератор Промптов</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('game') }}\"><i class=\"fas fa-gamepad\"></i> Игра MMSS</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('ai_assistant') }}\"><i class=\"fas fa-brain\"></i> AI Ассистент</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('orchestrator') }}\"><i class=\"fas fa-sitemap\"></i> Orchestrator</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('tasks_page') }}\"><i class=\"fas fa-tasks\"></i> Tasks</a></li>\n                        <li class=\"nav-item\"><a class=\"nav-link\" href=\"{{ url_for('settings_page') }}\"><i class=\"fas fa-cog\"></i> Настройки</a></li>\n                    </ul>\n                </div>\n            </div>\n        </nav>\n\n        {% with messages = get_flashed_messages(with_categories=true) %}\n            {% if messages %}\n                <div class=\"container mt-3\">\n                    {% for category, message in messages %}\n                        <div class=\"alert alert-{{ 'danger' if category == 'error' else category }} alert-dismissible fade show\" role=\"alert\">\n                            {{ message }}\n                            <button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"alert\"></button>\n                        </div>\n                    {% endfor %}\n                </div>\n            {% endif %}\n        {% endwith %}\n\n        <main class=\"container my-5\">\n            {% block content %}{% endblock %}\n        </main>\n    </div>\n\n    <div id=\"gl-source-panels\">\n        <div id=\"gl-nav-source\" class=\"gl-source-panel gl-nav-panel\"></div>\n        <div id=\"gl-main-source\" class=\"gl-source-panel gl-content-panel\"></div>\n    </div>\n\n    <div id=\"golden-layout-root\"></div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/golden-layout@2.6.0/dist/bundle/umd/golden-layout.min.js\"></script>\n    <script src=\"{{ url_for('static', filename='js/main.js') }}\"></script>\n    <script src=\"{{ url_for('static', filename='js/theme.js') }}\"></script>\n    <script src=\"{{ url_for('static', filename='js/golden_layout_app.js') }}\"></script>\n    {% block scripts %}{% endblock %}\n</body>\n</html>\n</pre></body></html>",
